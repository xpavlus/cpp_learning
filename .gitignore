# C++ / CMake / Visual Studio / VS Code — .gitignore

# ──────────────────────────────────────────────
# Build output directories
# ──────────────────────────────────────────────
build/
out/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
_deps/

# ──────────────────────────────────────────────
# Compiled object files and binaries
# ──────────────────────────────────────────────
*.obj
*.o
*.exe
*.dll
*.lib
*.a
*.so
*.pdb
*.ilk
*.exp
*.idb
*.iobj
*.ipdb
*.map
*.pgc
*.pgd
*.rsp
*.sbr
*.tlog
*.lastbuildstate
*.log

# ──────────────────────────────────────────────
# Visual Studio
# ──────────────────────────────────────────────
.vs/
*.VC.db
*.VC.VC.opendb
*.sdf
*.opensdf
*.suo
*.user
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.props
*.targets
x64/
x86/
Debug/
Release/
RelWithDebInfo/
MinSizeRel/

# ──────────────────────────────────────────────
# VS Code
# ──────────────────────────────────────────────
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# ──────────────────────────────────────────────
# CLion
# ──────────────────────────────────────────────
.idea/
cmake-build-*/

# ──────────────────────────────────────────────
# Ninja
# ──────────────────────────────────────────────
*.ninja
*.ninja_deps
*.ninja_log
.ninja_deps
.ninja_log

# ──────────────────────────────────────────────
# Windows system
# ──────────────────────────────────────────────
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
